{
  "expo": {
    "name": "Sprightly Wand",
    "slug": "sprightly-wand",
    "scheme": "sprightlywand",
    "version": "1.2.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b3d2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sprightly.wand",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sprightly.wand",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b3d2e"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0b3d2e"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "21012431-b1b2-49dd-9646-3563e040afce"
      },
      "google": {
        "_comment": "OAuth 2.0 client IDs from Google Cloud Console. Required for Google sign-in. webClientId is also the audience Firebase verifies the ID token against.",
        "webClientId": "647438884542-pcne160pbmt57kdq2barpgv2vit6nvcs.apps.googleusercontent.com",
        "androidClientId": "647438884542-hqjhm04t8d9dehcnpims8r8ftnej184h.apps.googleusercontent.com"
      }
    }
  }
}
