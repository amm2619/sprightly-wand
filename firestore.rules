rules_version = '2';

// Security rules for Sprightly Wand — a private two-player card game.
//
// Posture (anonymous auth, a known pair of players, no sensitive data):
//  - Every request must be authenticated.
//  - Any signed-in client may READ a room — a player has to read a room in
//    order to join it, and the per-game room codes are static/shared anyway.
//  - Only the two players listed in `players` may WRITE room/game state. A
//    non-member may perform exactly the one update that seats themselves.
//  - privateHands / privateSlots are the only real secret (your opponent's
//    cards): readable only by their owner. The host may additionally read a
//    hand while scoring a finished hand, and writes both players' hands/slots
//    when dealing a new round.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // The room as it will be once the current operation commits.
    //
    // We deliberately use getAfter() rather than get(): the host deals a new
    // round in a SINGLE transaction that writes the room doc AND both players'
    // private hands/slots. A plain get() of the room from inside the
    // privateHands/privateSlots rule does not resolve while the room is part
    // of that same write set, which denied the host's deal. getAfter() reads
    // the post-commit state, which is correct here — neither hostUid nor the
    // statuses we check are mutated in a way that would weaken these rules.
    function roomAfter(code) {
      return getAfter(/databases/$(database)/documents/rooms/$(code)).data;
    }

    function isMember(data) {
      return isSignedIn() && (request.auth.uid in data.players);
    }

    function isHost(code) {
      return isSignedIn() && roomAfter(code).hostUid == request.auth.uid;
    }

    match /rooms/{code} {
      // Create a fresh room: you are the host and the only player.
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.players.keys().hasOnly([request.auth.uid]);

      // Rooms aren't secret; a client must be able to read one to join it.
      allow read: if isSignedIn();

      // Members drive all game state. A non-member may only make the single
      // update that seats themselves — a plain join, or reclaiming a stale
      // same-nickname seat — and may never grow the room past two players.
      allow update: if isMember(resource.data)
        || (
          isSignedIn()
          && !(request.auth.uid in resource.data.players)
          && (request.auth.uid in request.resource.data.players)
          && request.resource.data.players.size() <= 2
        );

      allow delete: if isSignedIn() && resource.data.hostUid == request.auth.uid;

      // Each player's face-down cards. Readable only by the owner; the host
      // may also read while scoring a finished hand. Writable by the owner,
      // and by the host (who deals both hands at the start of a round).
      match /privateHands/{uid} {
        allow read: if isSignedIn() && (
          request.auth.uid == uid
          || (isHost(code) && roomAfter(code).status in ['handOver', 'gameOver'])
        );
        allow write: if isSignedIn() && (
          request.auth.uid == uid || isHost(code)
        );
      }

      // Trash face-down slots. Readable only by the owner; writable by the
      // owner and by the host (who deals both grids at the start of a round).
      match /privateSlots/{uid} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if isSignedIn() && (
          request.auth.uid == uid || isHost(code)
        );
      }
    }
  }
}
