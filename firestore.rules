rules_version = '2';

// Security rules for Sprightly Wand.
//
// Design:
//  - Anyone signed in (anonymous auth) can CREATE a room; the creator becomes hostUid.
//  - Only the two players whose uids are in `players` may read or update the room.
//  - Subcollection `privateHands/{uid}` is readable only by that uid (hands stay secret).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    function isMember(roomData) {
      return isSignedIn()
        && roomData.players.keys().hasAny([request.auth.uid]);
    }

    match /rooms/{code} {
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.players.keys().hasOnly([request.auth.uid]);

      allow read, update: if isMember(resource.data);
      allow delete: if isSignedIn() && resource.data.hostUid == request.auth.uid;

      // A joining player can add themselves to players even if not yet a member.
      // Allowed as long as the only change is inserting their own uid.
      allow update: if isSignedIn()
        && !(request.auth.uid in resource.data.players)
        && request.auth.uid in request.resource.data.players
        && request.resource.data.players.size() == resource.data.players.size() + 1;

      match /privateHands/{uid} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if isMember(get(/databases/$(database)/documents/rooms/$(code)).data);
      }
    }
  }
}
